#!/bin/bash

# --- Aesthetic Header ---
echo -e "\e[34m"
echo "-------------------------------------------------------"
echo "   🚀 NOVADEBLOAT: SELECTIVE SYSTEM PURGE              "
echo "-------------------------------------------------------"
echo -e "\e[0m"

# 1. Gather the "Bloat" categories
echo -e "\e[1;32m[+] Scanning for system clutter...\e[0m\n"

# Check for Orphans
orphans=$(pacman -Qdtq)
# Check Cache Size
cache_size=$(du -sh /var/cache/pacman/pkg/ 2>/dev/null | cut -f1)
# Check Journal Logs
journal_size=$(journalctl --disk-usage | awk '{print $7}')

# 2. Display the Menu
echo "Select which files to remove (e.g., 1 3):"
echo "---------------------------------------"
[[ -n "$orphans" ]] && echo "1) Orphaned Packages ($orphans)" || echo "1) [CLEAN] No Orphans found"
echo "2) Pacman Cache (Currently: $cache_size)"
echo "3) System Logs (Currently: $journal_size)"
echo "4) All of the above"
echo "5) Cancel and Exit"
echo "---------------------------------------"

read -p "Enter numbers: " selections

# 3. Logic to handle numeric choices
for choice in $selections; do
    case $choice in
        1)
            if [[ -n "$orphans" ]]; then
                echo -e "\n\e[1;33m[!] Removing Orphans...\e[0m"
                sudo pacman -Rs $orphans[cite: 1]
            fi
            ;;
        2)
            echo -e "\n\e[1;33m[!] Cleaning Pacman Cache (Keeping last 1)...\e[0m"
            sudo paccache -rk 1[cite: 1]
            ;;
        3)
            echo -e "\n\e[1;33m[!] Vacuuming Logs to 2 days...\e[0m"
            sudo journalctl --vacuum-time=2d
            ;;
        4)
            echo -e "\n\e[1;31m[!!!] FULL PURGE INITIALIZED [!!!]\e[0m"
            [[ -n "$orphans" ]] && sudo pacman -Rs $orphans[cite: 1]
            sudo paccache -rk 1[cite: 1]
            sudo journalctl --vacuum-time=2d
            ;;
        5)
            echo "Exiting NovaDebloat."
            exit 0
            ;;
    esac
done

echo -e "\n\e[34m-------------------------------------------------------\e[0m"
echo "NovaDebloat Complete. Your Arch install is now lean."
