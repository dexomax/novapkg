#!/bin/bash

# Nova Colors
BLUE='\033[1;34m'
GREEN='\033[1;32m'
RED='\033[1;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# The Logo
echo -e "${BLUE}"
echo "  _   _                 ____  _              "
echo " | \ | | _____   ____ _|  _ \| | ____ _      "
echo " |  \| |/ _ \ \ / / _\` | |_) | |/ / _\` |    "
echo " | |\  | (_) \ V / (_| |  __/|   < (_| |     "
echo " |_| \_|\___/ \_/ \__,_|_|   |_|\_\__, |     "
echo "                                  |___/      "
echo -e "${NC}"
echo -e "${GREEN}--- Nova Package Manager v1.0 ---${NC}"
echo ""

# Logic
case "$1" in
    install)
        echo -e "${YELLOW}[*] Nova Engine: Fetching ${@:2}...${NC}"
        sudo pacman -S "${@:2}"
        ;;
    update)
        echo -e "${BLUE}[*] Nova Engine: Syncing system databases...${NC}"
        sudo pacman -Syu
        ;;
    remove)
        echo -e "${RED}[!] Nova Engine: Removing ${@:2}...${NC}"
        sudo pacman -Rns "${@:2}"
        ;;
    search)
        echo -e "${YELLOW}[*] Nova Engine: Searching for ${@:2}...${NC}"
        pacman -Ss "${@:2}"
        ;;
    *)
        echo "Usage: novapkg {install|update|remove|search} [package]"
        ;;
esac
